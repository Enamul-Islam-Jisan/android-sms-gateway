<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Compact Status Header -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="12dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/rounded_background"
            android:backgroundTint="@color/slate_500" />

        <TextView
            android:id="@+id/textStatusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Status: Offline"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
            android:textColor="@color/slate_900"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/buttonStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="0.8"
            android:scaleY="0.8" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slate_200" />

    <!-- Metrics Row (High Density) -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="0dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/totalProcessed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="@color/slate_900"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/slate_500" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/slate_200" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/pendingQueue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUEUE"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/slate_500" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/slate_200" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/deliveredCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="@color/secondary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENT"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/slate_500" />
        </LinearLayout>

    </androidx.appcompat.widget.LinearLayoutCompat>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slate_200" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Service Toggles -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="INFRASTRUCTURE"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="@color/slate_500"
                android:textStyle="bold" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_local_server"
                    app:tint="@color/slate_500" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Local Node"
                    android:textColor="@color/slate_900" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchUseLocalServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_cloud_server"
                    app:tint="@color/slate_500" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Cloud Link"
                    android:textColor="@color/slate_900" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchUseRemoteServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/slate_200" />

            <!-- Expandable System Details -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/layoutDetailsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SYSTEM DETAILS"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                    android:textColor="@color/slate_500"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imageDetailsArrow"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_advanced"
                    app:tint="@color/slate_500" />
            </androidx.appcompat.widget.LinearLayoutCompat>

            <GridLayout
                android:id="@+id/layoutDetailsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/slate_50"
                android:columnCount="2"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Local IP" />

                <TextView
                    android:id="@+id/textLocalIP"
                    style="@style/HomeCardValue"
                    tools:text="192.168.1.10:8080" />

                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Public IP" />

                <TextView
                    android:id="@+id/textPublicIP"
                    style="@style/HomeCardValue"
                    tools:text="1.2.3.4:8080" />

                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Local User" />

                <TextView
                    android:id="@+id/textLocalUsername"
                    style="@style/HomeCardValue"
                    tools:text="admin" />

                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Cloud ID" />

                <TextView
                    android:id="@+id/textRemoteDeviceId"
                    style="@style/HomeCardValue"
                    tools:text="abc-123" />

                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Cloud User" />

                <TextView
                    android:id="@+id/textRemoteUsername"
                    style="@style/HomeCardValue"
                    tools:text="user_99" />
                
                <TextView
                    style="@style/HomeCardLabel"
                    android:text="Cloud Host" />

                <TextView
                    android:id="@+id/textRemoteAddress"
                    style="@style/HomeCardValue"
                    tools:text="api.sms-gate.app" />

            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/slate_200" />
            
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutostart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Start on boot"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                android:textColor="@color/slate_900" />

        </LinearLayout>
    </ScrollView>

    <!-- Tiny Ticker -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/slate_200" />

    <TextView
        android:id="@+id/textConnectionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="System idle"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
        android:textColor="@color/slate_500"
        android:maxLines="1"
        android:ellipsize="end" />

</androidx.appcompat.widget.LinearLayoutCompat>